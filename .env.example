# MongoDB — instance LOCALE en replica set (comme tes autres projets).
# Connexion directe à 127.0.0.1, sans ?replicaSet= (le driver découvre le set).
DATABASE_URL="mongodb://127.0.0.1:27017/israel_guides"
# Distante / authentifiée :
# DATABASE_URL="mongodb://USER:PASS@HOST:27017/israel_guides?authSource=admin"
# Atlas :
# DATABASE_URL="mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/israel_guides?retryWrites=true&w=majority"

# openssl rand -base64 33
AUTH_SECRET="change-me"
AUTH_URL="http://localhost:3000"

# Public
NEXT_PUBLIC_SITE_NAME="Israel Guides"
NEXT_PUBLIC_WHATSAPP="+972500000000"

# Vidéo de fond du hero (optionnel). Dépose ex public/img/hero.mp4 puis :
# NEXT_PUBLIC_HERO_VIDEO="/img/hero.mp4"

# Image de fond du hero (dans public/img). Défaut /img/kotel.jpg
# NEXT_PUBLIC_HERO_IMAGE="/img/mon-hero.jpg"

# Emails (Resend) — réutilise ton compte Tibeb
RESEND_API_KEY=""
# Expéditeur vérifié sur ton domaine (sinon garde le from de test)
EMAIL_FROM="Israly <onboarding@resend.dev>"
ADMIN_EMAIL="sudosudev@outlook.com"
# Lien de paiement (Grow/Meshulam) — optionnel pour l'instant
PAYMENT_URL=""
